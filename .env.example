PORT=8080
APP_ENV=development

# DATABASE_URL takes precedence over the individual DB_* settings. Use it for
# managed PostgreSQL providers, for example: postgresql://user:password@host:5432/database?sslmode=require
# DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tenant_saas
DB_SSLMODE=disable

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY_HOURS=24
